# ============================================================
#  WorldEngine (novel-creator) 环境配置
#  复制此文件为 .env 并填入你的配置
#  cp .env.example .env
# ============================================================

# ── LLM API 配置 ─────────────────────────────────────────
# OpenAI 兼容接口 (支持 OpenAI / 月之暗面 / DeepSeek / 等)
NOVEL_OPENAI_API_KEY=sk-your-key-here
NOVEL_OPENAI_BASE_URL=https://api.openai.com/v1

# ── 模型配置 ─────────────────────────────────────────────
# Director: 故事总规划 (需要强推理能力, 推荐 gpt-4o)
NOVEL_DIRECTOR_MODEL=gpt-4o
# Character: 角色Agent (调用频繁, 推荐性价比模型)
NOVEL_CHARACTER_MODEL=gpt-4o-mini
# Writer: 史官/叙述 (需要文学表达力)
NOVEL_WRITER_MODEL=gpt-4o
# God: 命运之手 (留空则使用 Director 模型)
# NOVEL_GOD_MODEL=

# ── 数据库 ───────────────────────────────────────────────
NOVEL_DB_PATH=data/novel.db

# ── 向量嵌入 ─────────────────────────────────────────────
NOVEL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ── Web 服务 ─────────────────────────────────────────────
NOVEL_WEB_HOST=0.0.0.0
NOVEL_WEB_PORT=8000
