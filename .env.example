# ============================================================
#  WorldEngine (novel-creator) 环境配置
#  复制此文件为 .env 并填入你的配置
#  cp .env.example .env
# ============================================================

# ── LLM API 配置 (支持多种 Provider) ────────────────────
#
# 方式一: OpenAI 官方
#   NOVEL_OPENAI_API_KEY=sk-...
#   NOVEL_OPENAI_BASE_URL=https://api.openai.com/v1
#
# 方式二: OpenRouter (推荐, 一键切换)
#   NOVEL_LLM_PROVIDER=openrouter
#   NOVEL_OPENROUTER_API_KEY=sk-or-v1-...
#   NOVEL_DIRECTOR_MODEL=openai/gpt-4o
#   NOVEL_CHARACTER_MODEL=openai/gpt-4o-mini
#   NOVEL_WRITER_MODEL=openai/gpt-4o
#
# 方式三: 其他兼容接口 (DeepSeek / 月之暗面 / 本地 Ollama)
#   NOVEL_OPENAI_API_KEY=your-key
#   NOVEL_OPENAI_BASE_URL=https://api.deepseek.com/v1
#   NOVEL_DIRECTOR_MODEL=deepseek-chat

# LLM Provider: "openrouter" 或留空(默认用 openai_base_url)
NOVEL_LLM_PROVIDER=
NOVEL_OPENAI_API_KEY=sk-your-key-here
NOVEL_OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter 专用 (当 NOVEL_LLM_PROVIDER=openrouter 时生效)
NOVEL_OPENROUTER_API_KEY=
# NOVEL_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── 模型配置 ─────────────────────────────────────────────
# Director: 故事总规划 (需要强推理能力, 推荐 gpt-4o)
NOVEL_DIRECTOR_MODEL=gpt-4o
# Character: 角色Agent (调用频繁, 推荐性价比模型)
NOVEL_CHARACTER_MODEL=gpt-4o-mini
# Writer: 史官/叙述 (需要文学表达力)
NOVEL_WRITER_MODEL=gpt-4o
# God: 命运之手 (留空则使用 Director 模型)
# NOVEL_GOD_MODEL=

# ── 数据库 ───────────────────────────────────────────────
NOVEL_DB_PATH=data/novel.db

# ── 向量嵌入 ─────────────────────────────────────────────
NOVEL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ── 认证与安全 ──────────────────────────────────────────
# JWT密钥（生产环境必须修改！）
NOVEL_JWT_SECRET=change-me-in-production-to-random-string
# 管理员邀请码前缀（以此前缀开头的code自动获得admin权限）
NOVEL_ADMIN_CODE_PREFIX=admin
# CORS来源（生产环境限制为具体域名，如 https://yourdomain.com）
NOVEL_CORS_ORIGINS=*

# ── Web 服务 ─────────────────────────────────────────────
NOVEL_WEB_HOST=0.0.0.0
NOVEL_WEB_PORT=8000
